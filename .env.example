NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Email (Resend — https://resend.com)
RESEND_API_KEY=

# The public URL of this deployment (used in email links)
NEXT_PUBLIC_SITE_URL=https://internal-medical-training.vercel.app

# Supabase service-role key (server-only — NEVER expose to client)
# Required for: deadline reminder cron, sending enrollment emails via auth.admin
SUPABASE_SERVICE_ROLE_KEY=

# Vercel Cron authentication secret — set the same value in Vercel project env vars
CRON_SECRET=
